# ==========================================
# KrishiSaarthi Environment Variables
# ==========================================

# 1. MongoDB Configuration
# Get this from MongoDB Atlas (replace <username>, <password>, <cluster>)
MONGODB_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app_name>"
DATABASE_NAME="krishisarthi"

# 2. Django Security Settings
# Generate a random secret key for production
SECRET_KEY="your-django-insecure-key-change-this"
DEBUG=True

# 3. AI Providers
# Gemini is the primary LLM used for the RAG Assistant & Soil Analysis OCR
GEMINI_API_KEYS="YOUR_GEMINI_API_KEY_HERE"
GEMINI_MODEL="gemini-2.0-flash"

# Optional Fallback LLM (Groq)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
